<Window x:Class="ControlAcceso.VentanaAdministrar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Administración"
        Height="450" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. BARRA DE NAVEGACIÓN -->
        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,15">
            <Button x:Name="btnNavReporte" Content="Reporte General" Height="30" Click="BtnNavReporte_Click" FontWeight="Bold"/>
            <Button x:Name="btnNavRegistrar" Content="Registrar Empleado" Height="30" Click="BtnNavRegistrar_Click"/>
            <Button x:Name="btnNavConfig" Content="Configuración" Height="30" Click="BtnNavConfig_Click"/>
        </UniformGrid>

        <!-- 2. CONTENIDO PRINCIPAL -->

        <!-- Panel 1: Reporte General con Tabla -->
        <Grid x:Name="panelReporte" Grid.Row="1" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Reporte de Asistencia Diaria" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1"
                      x:Name="dgvReporteDiario"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      VerticalGridLinesBrush="LightGray"
                      HorizontalGridLinesBrush="LightGray"
                      BorderThickness="1"
                      BorderBrush="Gray">
                <DataGrid.Columns>
    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
    <DataGridTextColumn Header="Cédula" Binding="{Binding Cedula}" Width="80"/>
    <DataGridTextColumn Header="Hora Entrada" Binding="{Binding HoraEntrada}" Width="95"/>
    <DataGridTextColumn Header="Hora Salida" Binding="{Binding HoraSalida}" Width="95"/>
    <DataGridTextColumn Header="Retraso" Binding="{Binding Retraso}" Width="85"/>
    <DataGridTextColumn Header="T. Extra" Binding="{Binding TiempoExtra}" Width="85"/>
    <DataGridTextColumn Header="Total Lab." Binding="{Binding TiempoTrabajado}" Width="90"/>
</DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Panel 2: Registrar Empleado -->
        <Grid x:Name="panelRegistrar" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="340">
                <TextBlock Text="Registro de Nuevo Empleado" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Nombre:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                    <TextBox x:Name="txtNombreEmpleado" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5" Height="26" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="Identificación:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                    <TextBox x:Name="txtCedulaEmpleado" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5" Height="26" VerticalContentAlignment="Center"/>
                </Grid>

                <Button x:Name="btnGuardarEmpleado"
                        Content="Escanear Huella y Guardar"
                        Height="35"
                        Margin="0,20,0,0"
                        FontWeight="Bold"
                        Click="BtnGuardarEmpleado_Click"/>
            </StackPanel>
        </Grid>

        <!-- Panel 3: Configuración -->
        <Grid x:Name="panelConfiguracion" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="340">
                <TextBlock Text="Configuración del Sistema" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Hora Entrada:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,5">
                        <ComboBox x:Name="cmbHoraEntrada" Width="65" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="hrs" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="Gray" FontSize="11"/>

                        <ComboBox x:Name="cmbMinutoEntrada" Width="65" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="min" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray" FontSize="11"/>
                    </StackPanel>

                    <Label Grid.Row="1" Grid.Column="0" Content="Hora Salida:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,5">
                        <ComboBox x:Name="cmbHoraSalida" Width="65" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="hrs" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="Gray" FontSize="11"/>

                        <ComboBox x:Name="cmbMinutoSalida" Width="65" Height="26" VerticalContentAlignment="Center"/>
                        <TextBlock Text="min" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray" FontSize="11"/>
                    </StackPanel>

                    <Label Grid.Row="2" Grid.Column="0" Content="Contraseña:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                    <PasswordBox x:Name="txtPassword" Grid.Row="2" Grid.Column="1" Margin="0,5,0,5" Height="26" VerticalContentAlignment="Center"/>
                </Grid>

                <Button x:Name="btnGuardarConfig"
                        Content="Guardar Configuración"
                        Height="32"
                        Margin="0,15,0,0"
                        FontWeight="Bold"
                        Click="BtnGuardarConfig_Click"/>
            </StackPanel>
        </Grid>

        <!-- 3. BOTÓN SALIR -->
        <Button Grid.Row="2"
                Content="Volver al Menú"
                Width="120"
                Height="35"
                Click="BtnVolver_Click"
                HorizontalAlignment="Center"
                Margin="0,15,0,0"/>
    </Grid>
</Window>
