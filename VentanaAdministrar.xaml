<Window x:Class="ControlAcceso.VentanaAdministrar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Administración" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Contenido de prueba para verificar la comunicación -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Panel de Administración"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="lblEstado"
                       Text="Cargando datos..."
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- Botón de salida -->
        <Button Grid.Row="1"
                Content="Volver al Menú"
                Width="120"
                Height="35"
                Click="BtnVolver_Click"
                HorizontalAlignment="Center"/>
    </Grid>
</Window>
