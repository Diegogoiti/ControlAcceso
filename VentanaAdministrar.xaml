<Window x:Class="ControlAcceso.VentanaAdministrar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Administración"
        Height="350" Width="450"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Fila para pestañas/botones de navegación: se ajusta al contenido -->
            <RowDefinition Height="Auto"/>
            <!-- Fila para el contenido dinámico: toma todo el espacio vertical disponible -->
            <RowDefinition Height="*"/>
            <!-- Fila para el botón de cerrar: se ajusta al contenido -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. BARRA DE NAVEGACIÓN -->
        <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,15">
            <Button x:Name="btnNavReporte" Content="Reporte General" Height="30" Click="BtnNavReporte_Click" FontWeight="Bold"/>
            <Button x:Name="btnNavConfig" Content="Configuración" Height="30" Click="BtnNavConfig_Click"/>
        </UniformGrid>

        <!-- 2. CONTENIDO (Se expandirá vertical y horizontalmente) -->
        <!-- Panel 1: Reporte General (Visible por defecto) -->
        <Grid x:Name="panelReporte" Grid.Row="1" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Reporte General" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock x:Name="lblTotalEmpleados" Text="Total Empleados: --" FontSize="14" Margin="5" HorizontalAlignment="Center"/>
                <TextBlock x:Name="lblTotalAsistencias" Text="Total Asistencias: --" FontSize="14" Margin="5" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Panel 2: Configuración (Oculto por defecto) -->
        <Grid x:Name="panelConfiguracion" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Configuración del Sistema" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="[ Aquí podrás configurar parámetros del lector ]" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 3. BOTÓN SALIR -->
        <Button Grid.Row="2"
                Content="Volver al Menú"
                Width="120"
                Height="35"
                Click="BtnVolver_Click"
                HorizontalAlignment="Center"
                Margin="0,15,0,0"/>
    </Grid>
</Window>
