<Window x:Class="ControlAcceso.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Control de Acceso" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Fila para el botón: se ajusta al contenido -->
            <RowDefinition Height="Auto"/>
            <!-- Fila para la tabla: toma todo el espacio restante -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de control superior con el botón -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="btnMarcarAsistencia"
                    Content="Marcar Entrada/Salida"
                    Width="180"
                    Height="35"
                    FontSize="14"
                    FontWeight="Bold"/>
          <Button x:Name="btnAdministrar"
        Content="Administrar"
        Width="120"
        Height="35"
        Margin="10,0,0,0"
        FontSize="14"
        FontWeight="Bold"
        Click="btnAdministrar_Click"/>
        </StackPanel>

        <!-- Tabla de datos -->
        <DataGrid Grid.Row="1"
                  x:Name="dgvEmpleados"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  VerticalGridLinesBrush="LightGray"
                  HorizontalGridLinesBrush="LightGray"
                  BorderThickness="1"
                  BorderBrush="Gray"
                  MouseDoubleClick="dgvEmpleados_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Datos.id}" Width="60"/>
    <DataGridTextColumn Header="Nombre" Binding="{Binding Datos.Nombre}" Width="*"/>
    <DataGridTextColumn Header="Cédula" Binding="{Binding Datos.Cedula}" Width="150"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
