<Window x:Class="ControlAcceso.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control de Acceso de Personal" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Encabezado -->
            <RowDefinition Height="Auto"/>
            <!-- Tabla Principal -->
            <RowDefinition Height="*"/>
            <!-- Barra de Acciones / Botones -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Sistema de Control de Acceso" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Panel Principal de Monitoreo de Personal" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>

                <Button x:Name="btnAdministrar" Grid.Column="1" Content="⚙️ Administración"
                        Click="btnAdministrar_Click" Padding="12,6"
                        Background="#334155" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- TABLA PRINCIPAL (DataGrid) -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgvEmpleados"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="40"
                      MouseDoubleClick="dgvEmpleados_MouseDoubleClick">

                <DataGrid.Resources>
                    <!-- Estilo para centrar celdas específicas -->
                    <Style x:Key="CenterElement" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <!-- Estilo general para texto en celdas -->
                    <Style x:Key="LeftElement" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="10,0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Datos.Id}"
                                        Width="70"
                                        ElementStyle="{StaticResource CenterElement}"/>

                    <DataGridTextColumn Header="Nombre Completo"
                                        Binding="{Binding Datos.Nombre}"
                                        Width="*"
                                        ElementStyle="{StaticResource LeftElement}"/>

                    <DataGridTextColumn Header="Cédula"
                                        Binding="{Binding Datos.Cedula}"
                                        Width="160"
                                        ElementStyle="{StaticResource CenterElement}"/>

                    <DataGridTextColumn Header="Estado Actual"
                                        Binding="{Binding Estado}"
                                        Width="120"
                                        ElementStyle="{StaticResource CenterElement}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- BARRA DE ACCIONES ABAJO -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnMarcarAsistencia"
                    Content="📌 Registrar Asistencia"
                    Padding="16,10"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#2563EB"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
