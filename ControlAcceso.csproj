<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Habilitar WPF -->
    <UseWPF>true</UseWPF>
    <!-- Deshabilitar WinForms -->
    <UseWindowsForms>false</UseWindowsForms>

    <!-- Compatibilidad x86 para tus librerías de huellas -->
    <PlatformTarget>x86</PlatformTarget>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>

    <NoWarn>NU1902;NU1903</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Tus librerías de hardware y dependencias -->
    <None Update="ftrScanAPI.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MahApps.Metro" Version="2.4.11" />
    <PackageReference Include="MySql.Data" Version="9.7.0" />
    <!-- <PackageReference Include="OpenCvSharp4" Version="4.10.0.20241108" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.10.0.20241108" />-->
    <PackageReference Include="SourceAFIS" Version="3.14.0" />
  </ItemGroup>

</Project>
