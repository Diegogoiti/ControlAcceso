<Window x:Class="ControlAcceso.VentanaMarcacionManual"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marcación Manual de Asistencia"
        Height="210" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F7">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Información del Empleado -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="lblEmpleado"
                       Text="Empleado: "
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="#333333"/>
            <TextBlock x:Name="lblCedula"
                       Text="Cédula: "
                       FontSize="13"
                       Foreground="#666666"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Selección del Tipo de Marcación -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,5">
            <RadioButton x:Name="rbEntrada"
                         Content="Registrar Entrada"
                         FontSize="14"
                         Margin="0,0,20,0"
                         IsChecked="True"/>
            <RadioButton x:Name="rbSalida"
                         Content="Registrar Salida"
                         FontSize="14"/>
        </StackPanel>

        <!-- Botones de Acción -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">

            <Button x:Name="btnCancelar"
                    Content="Cancelar"
                    Width="90" Height="28"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Click="BtnCancelar_Click"/>

            <Button x:Name="btnGuardar"
                    Content="Confirmar"
                    Width="90" Height="28"
                    IsDefault="True"
                    FontWeight="SemiBold"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
