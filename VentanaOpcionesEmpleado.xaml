<Window x:Class="ControlAcceso.VentanaOpcionesEmpleado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Empleado"
        Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Información del Empleado -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="lblNombre" Text="Nombre: " FontSize="16" FontWeight="Bold"/>
            <TextBlock x:Name="lblCedula" Text="Cédula: " FontSize="14" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Estado Actual -->
        <Border Grid.Row="1" Padding="8" Background="#F0F0F0" CornerRadius="4" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Estado Actual: " FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblEstado" Text="Activo" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Acciones principales -->
        <UniformGrid Grid.Row="2" Columns="2" Rows="1" Margin="0,10,0,0">
            <Button x:Name="btnCambiarEstado"
                    Content="Desactivar"
                    Margin="5"
                    Height="40"
                    FontWeight="Bold"
                    Click="BtnCambiarEstado_Click"/>

            <Button x:Name="btnActualizarHuella"
                    Content="Actualizar Huella"
                    Margin="5"
                    Height="40"
                    FontWeight="Bold"
                    Click="BtnActualizarHuella_Click"/>
        </UniformGrid>
    </Grid>
</Window>
