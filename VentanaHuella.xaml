<Window x:Class="ControlAcceso.VentanaHuella"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Captura de Huella" Height="200" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock x:Name="lblMensaje" Text="Coloque su dedo..." HorizontalAlignment="Center"/>
        <Button Content="Capturar Huella" Click="BtnCapturar_Click" Margin="0,10,0,0"/>
        <Button Content="Cerrar" Click="BtnCerrar_Click" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
